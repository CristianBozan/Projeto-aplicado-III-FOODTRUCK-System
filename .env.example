# ─────────────────────────────────────────────
# Food Truck System v3.0 — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ─────────────────────────────────────────────

# Banco de Dados MySQL
DB_NAME=sistema_pedidos
DB_USER=foodtruck_user
DB_PASS=123456
DB_HOST=localhost
DB_PORT=3306
DB_DIALECT=mysql

# Servidor
PORT=3000

# Token de proteção dos endpoints de backup (opcional)
BACKUP_TOKEN=foodtruck_backup_2026

# Credenciais padrão — Gerente (acesso total)
GERENTE_LOGIN=admin
GERENTE_SENHA=admin123

# Credenciais padrão — Atendente (acesso operacional)
ATENDENTE_LOGIN=funcionario
ATENDENTE_SENHA=func123
